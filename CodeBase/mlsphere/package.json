{
  "name": "mlsphere",
  "version": "1.0.0",
  "description": "MLSphere - Visual Machine Learning Pipeline Creator with drag-and-drop ML blocks",
  "private": true,
  "scripts": {
    "serve": "node \"local-server/CodeBase/Local Server/serve-with-agent.js\"",
    "serve:web": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "local-server:start": "node \"local-server/CodeBase/Local Server/server.js\"",
    "release:local-server": "powershell -ExecutionPolicy Bypass -File \"local-server/CodeBase/Release Script/package-agent.ps1\"",
    "release:local-server:skip-install": "powershell -ExecutionPolicy Bypass -File \"local-server/CodeBase/Release Script/package-agent.ps1\" -SkipInstall",
    "release:local-server:sh": "bash \"local-server/CodeBase/Release Script/package-agent.sh\""
  },
  "dependencies": {
    "axios": "^1.13.5",
    "chart.js": "^4.5.1",
    "codemirror": "^5.65.21",
    "core-js": "^3.8.3",
    "vue": "^3.5.13",
    "vue-router": "^4.6.3",
    "vuex": "^4.1.0",
    "vue-chartjs": "^5.3.3",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "@vue/compiler-sfc": "^3.5.13"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
